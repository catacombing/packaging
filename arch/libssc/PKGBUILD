pkgname=libssc
pkgdesc="Library to expose Qualcomm Sensor Core sensors"
pkgver=0.4.0
pkgrel=1
arch=("x86_64" "aarch64")
url="https://codeberg.org/DylanVanAssche/libssc"
license=("GPL-3.0-or-later")
makedepends=("meson" "libqmi" "qrtr" "protobuf-c")
source=("git+$url.git#tag=v$pkgver")
sha256sums=("35fdba4696f15a5d070806072324bae1bbfa7f9d4133ea270dea1ce555007bfe")

build() {
    arch-meson $pkgname build -Db_lto=true
    meson compile -C build
}

package() {
    meson install -C build --destdir "$pkgdir"
}
