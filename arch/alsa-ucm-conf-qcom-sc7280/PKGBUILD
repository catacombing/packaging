pkgname=alsa-ucm-conf-qcom-sc7280
pkgdesc="ALSA UCM configuration for SC7280 devices"
pkgver=r921.1f98b6a
pkgrel=4
arch=("aarch64")
url="https://github.com/sc7280-mainline/alsa-ucm-conf"
license=("BSD-3-Clause")
provides=("alsa-ucm-conf")
conflicts=("alsa-ucm-conf")
_commit="9d5563e6456e1a35e2d59c59130c50b2bbfe3c94"
source=("git+$url.git#commit=$_commit")
sha256sums=("a651ed054e28a883c8d7a5ac9e5e4b5c79bc01008077eadbc9206c6b62e470fd")

pkgver() {
    cd "alsa-ucm-conf"

    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package() {
    cd "alsa-ucm-conf"

    mkdir -p "$pkgdir/usr/share/alsa"
    cp -r ucm2 "$pkgdir/usr/share/alsa/"
}
