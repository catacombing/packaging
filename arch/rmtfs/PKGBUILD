pkgname=rmtfs
pkgdesc="Qualcomm Remote Filesystem Service Implementation"
pkgver=1.2
pkgrel=2
arch=("x86_64" "aarch64")
url="https://github.com/linux-msm/rmtfs"
license=("BSD-3-Clause")
makedepends=("qrtr")
source=(
    "git+$url.git#tag=v$pkgver"
    "udev.rules"
)
sha256sums=(
    "4f652d9b3cd86be922150ee789f0176ce84f4d1b4afeeb6a20f5ec0c5a4ec0a3"
    "0c2f26d40d9d18e3089c6d836b64231c4f7e0c1ca41686fe7c9d1eb495dc6bbe"
)

build() {
    cd "$pkgname"

    make rmtfs
}

package() {
    cd "$pkgname"

    DESTDIR="$pkgdir" make prefix=/usr install

    install -D -m 644 "../udev.rules" "$pkgdir/usr/lib/udev/rules.d/65-rmtfs.rules"
}
